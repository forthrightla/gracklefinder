# Mapbox (required) — get a token at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxx

# Vercel KV (required) — provisioned automatically when you add the KV integration
KV_REST_API_URL=https://xxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxx

# Google Places API (pipeline only) — https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=AIza...

# Gemini API (pipeline only) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Shared secret for the /api/refresh endpoint (pipeline only)
REFRESH_SECRET=some-random-secret
